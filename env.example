# Live backend (market-backend). Set both so inventory uses the API instead of mock data.
# https://github.com/kelsey-developers/market-backend
API_URL=https://kelsey.idateph.com
NEXT_PUBLIC_API_URL=https://kelsey.idateph.com

# Payroll backend — used by /api/payroll-proxy to forward requests with auth token
PAYROLL_API_URL=http://localhost:4000

# Optional: dev auth for protected routes
NEXT_PUBLIC_DEV_AUTH_USER_ID=mock-1
NEXT_PUBLIC_DEV_AUTH_EMAIL=admin@example.com
NEXT_PUBLIC_DEV_AUTH_ROLE=admin
